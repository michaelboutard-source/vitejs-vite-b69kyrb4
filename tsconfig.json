{
  "compilerOptions": {
    "jsx": "react-jsx",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["src/lib/*"],
      "@db": ["src/db"],
      "@db/*": ["src/db/*"],
      "@pages/*": ["src/pages/*"],
      "@components/*": ["src/components/*"],
      "@i18n": ["src/i18n"],
      "@i18n/*": ["src/i18n/*"]
    }
  },
  "include": ["src"]
}
